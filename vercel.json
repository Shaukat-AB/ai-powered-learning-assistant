{
  "version": 2,
  "builds": [
    { "src": "client/dist/**", "use": "@vercel/static" },
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/src/index.ts"
    },
    { "src": "/(.*)", "dest": "/client/dist/index.html" }
  ]
}
