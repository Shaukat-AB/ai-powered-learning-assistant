{
  "version": 2,
  "builds": [
    { "src": "client/dist/**", "use": "@vercel/static" },
    { "src": "server/src/index.ts", "use": "@vercel/node" }
  ],

  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/src/index.ts" },
    { "source": "/(.*)", "destination": "/client/dist/index.html" }
  ]
}
